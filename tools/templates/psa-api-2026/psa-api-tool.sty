% The title page command
\newenvironment{psatitle}%
{
    \thispagestyle{empty}
    \setlength{\parindent}{0pt}

    % PDF information dictionary
    \begingroup
        \def\endgraf{ }\def\and{\& }%
        \pdfstringdefDisableCommands{\def\\{, }}% overwrite hyperref setup
        \hypersetup{%
            pdfauthor={\docauthor},%
            pdftitle={\docfulltitle},%
            pdfsubject={\docrelease}%
        }%
    \endgroup

    % Placeholder logo
    \noindent\begin{minipage}[t]{5.2cm}
        \vspace{0pt}% required to get top-alignment of image and text
        \sphinxlogo
    \end{minipage}
    \hfill\begin{minipage}[t]{0.67\textwidth}\raggedleft%
        \vspace{0pt}% required to get top-alignment of image and text
        {\psah \doclatextitle{} \par}
    \end{minipage}

    \bigskip\bigskip\bigskip

    \newcommand{\psatitlecopyright}{
        \medskip

        \begingroup\raggedleft
            \scriptsize{Copyright \textcopyright \doccopyright}\\\par
        \endgroup

        \bigskip\bigskip\bigskip\bigskip
    }
    % Title page information table, copyright and banner will follow
}
{
    \clearpage

    % Contents tables
    \pagestyle{plain}
    \pagenumbering{arabic}
    \begingroup
        \sphinxtableofcontents
        \iftotaltables\psalistoftables\fi
        \let\clearpage\relax    % prevent page break between tables
        \iftotalfigures\psalistoffigures\fi
    \endgroup

    \pagestyle{normal}
}

