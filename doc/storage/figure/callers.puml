@startuml

!include psa-spec.pumh
!include psa-dataflow.pumh

skinparam RectangleborderThickness 0
skinparam RectanglefontColor white
skinparam DatabaseBorderColor #PSAMidGray
skinparam InterfaceBorderColor #PSAMidGray

left to right direction

dfd_tb("Application boundary") {
   rectangle "Application 1" as caller1 #PSAMidGray
   interface "**Secure Storage API**" as api1  #PSAGreen
}
dfd_tb("Data protection boundary") {
rectangle "Storage service" as service #PSAMidBlue
database "Storage medium" as store #PSALightGray
}
dfd_tb("Application boundary") {
   interface "**Secure Storage API**" as api2  #PSAGreen
   rectangle "Application 2" as caller2 #PSAMidGray
}

caller1 -d- api1
api1 -d-> service
service <--> store
caller2 -d- api2
api2 -d-> service

@enduml
